{
  "rules": {
    ".read": false,
    ".write": false,
    "rooms": {
      "$code": {
        ".read": true,
        ".write": true,
        ".validate": "$code.length === 4",
        "chat": {
          "$msg": {
            "text": { ".validate": "newData.isString() && newData.val().length <= 200" }
          }
        }
      }
    }
  }
}
